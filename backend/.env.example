# PostgreSQL 接続URL
# 例: postgres://postgres:postgres@localhost:5432/fish_tech?sslmode=disable
DATABASE_URL=

# API起動ポート（未指定時: 8080）
PORT=8080

# 管理APIを許可するオリジン（カンマ区切り）
# 未指定時は http://localhost:3001 のみ許可
ADMIN_ALLOWED_ORIGINS=http://localhost:3001

# Google Photos連携（管理画面の画像アップロード用）
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=
GOOGLE_PHOTOS_REFRESH_TOKEN=

# 任意: 指定時はこのアルバムに保存
GOOGLE_PHOTOS_ALBUM_ID=

# HotPepper グルメサーチAPIキー
HOTPEPPER_API_KEY=

# Rakuten API
RAKUTEN_APP_URL=
RAKUTEN_APP_ID=
RAKUTEN_APP_ACCESS_KEY=
RAKUTEN_APP_AFILIATE_ID=
