{
  "openapi": "3.0.3",
  "info": {
    "title": "Fish-Tech API",
    "version": "1.0.0",
    "description": "Fish-Tech バックエンド API 仕様"
  },
  "servers": [
    {
      "url": "http://localhost:8080/api",
      "description": "ローカル backend"
    }
  ],
  "tags": [
    {
      "name": "Public"
    },
    {
      "name": "Place"
    },
    {
      "name": "Admin"
    }
  ],
  "paths": {
    "/hello": {
      "get": {
        "tags": ["Public"],
        "summary": "動作確認",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Hello fish-tech!"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fishes": {
      "get": {
        "tags": ["Public"],
        "summary": "魚一覧を取得",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Fish"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pairs": {
      "get": {
        "tags": ["Public"],
        "summary": "魚相性一覧を取得",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/FishPair"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/places/recommendations": {
      "get": {
        "tags": ["Place"],
        "summary": "おすすめ店舗を取得",
        "parameters": [
          {
            "name": "fishName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cityCode",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "favorite",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlaceRecommendationsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/places/favorite": {
      "patch": {
        "tags": ["Place"],
        "summary": "店舗のお気に入り状態を更新",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "placeId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "favorite",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePlaceFavoriteRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "更新成功"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/admin/fishes/upload-image": {
      "post": {
        "tags": ["Admin"],
        "summary": "画像を Google Photos へアップロード",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "作成成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadImageResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/admin/fishes": {
      "post": {
        "tags": ["Admin"],
        "summary": "魚を登録",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "description",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "imageUrl",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "imageMediaId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "linkUrl",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "作成成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminFish"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/admin/fishes/{id}": {
      "delete": {
        "tags": ["Admin"],
        "summary": "魚を削除",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "削除成功"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/admin/pairs": {
      "post": {
        "tags": ["Admin"],
        "summary": "魚相性を登録",
        "parameters": [
          {
            "name": "fishIdA",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fishIdB",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "score",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          },
          {
            "name": "memo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "作成成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FishPair"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/admin/pairs/{id}": {
      "delete": {
        "tags": ["Admin"],
        "summary": "魚相性を削除",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "削除成功"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "ErrorResponse": {
        "description": "エラーレスポンス",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "Fish": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "linkUrl": {
            "type": "string"
          }
        }
      },
      "AdminFish": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "imageMediaId": {
            "type": "string"
          },
          "linkUrl": {
            "type": "string"
          }
        }
      },
      "FishPair": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "fishIdA": {
            "type": "string"
          },
          "fishIdB": {
            "type": "string"
          },
          "score": {
            "type": "integer"
          },
          "memo": {
            "type": "string"
          }
        }
      },
      "RecommendedPlace": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          },
          "coupon": {
            "type": "string"
          },
          "genre": {
            "type": "string"
          },
          "card": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "isFavorite": {
            "type": "boolean"
          }
        }
      },
      "PlaceRecommendationsResponse": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "perPage": {
            "type": "integer"
          },
          "count": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecommendedPlace"
            }
          }
        }
      },
      "UpdatePlaceFavoriteRequest": {
        "type": "object",
        "required": ["userId", "placeId", "favorite"],
        "properties": {
          "userId": {
            "type": "string"
          },
          "placeId": {
            "type": "string"
          },
          "favorite": {
            "type": "boolean"
          }
        }
      },
      "UploadImageResponse": {
        "type": "object",
        "properties": {
          "imageUrl": {
            "type": "string"
          },
          "imageMediaId": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}
