    "basePath": "/api",
    "paths": {
        "/admin/fishes": {
            "post": {
                "description": "管理画面から魚を登録します。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Admin"
                ],
                "summary": "魚を登録",
                "parameters": [
                    {
                        "type": "string",
                        "description": "魚名",
                        "name": "name",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "カテゴリ",
                        "name": "category",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "説明",
                        "name": "description",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "画像URL",
                        "name": "imageUrl",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Google Photos の media ID",
                        "name": "imageMediaId",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "関連リンクURL",
                        "name": "linkUrl",
                        "in": "query"
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/handler.FishResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
