                    {
                        "type": "string",
                        "description": "店舗ID",
                        "name": "placeId",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "お気に入り状態",
                        "name": "favorite",
                        "in": "query"
                    },
                    {
                        "description": "後方互換用リクエストボディ",
