# フロントエンドから参照する API ベースURL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Swagger UI の Try it out 先
# 未指定時は NEXT_PUBLIC_API_BASE_URL を使用
NEXT_PUBLIC_SWAGGER_API_BASE_URL=http://localhost:8080/api

# サイトマップ生成用ドメイン
SITE_DOMAIN=https://example.com

# ログイン画面のサンプル表示用
NEXT_PUBLIC_LOGIN_EMAIL=
NEXT_PUBLIC_LOGIN_PASSWORD=
